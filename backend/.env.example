# Application
APP_NAME="chAs AI Creator"
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000

# Database (Use SQLite for now, or Supabase PostgreSQL)
DATABASE_URL=sqlite:///./app.db
# OR: postgresql://user:password@db.supabase.co:5432/postgres

# Redis (Optional - can disable if not available)
REDIS_URL=redis://localhost:6379/0

# AI Services (HuggingFace works in Nigeria ✓)
HUGGINGFACE_API_KEY=hf_your_actual_key_here

# REMOVE: OpenAI (blocked in Nigeria)
# OPENAI_API_KEY=sk-...

# Payments - Paystack (Nigeria ✓)
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here

# REMOVE: Stripe (blocked in Nigeria)
# STRIPE_SECRET_KEY=...
# STRIPE_PUBLISHABLE_KEY=...
# STRIPE_WEBHOOK_SECRET=...

# Storage - Cloudinary (Global ✓)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# REMOVE: AWS (can use but expensive)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=...
# AWS_S3_BUCKET=...

# REMOVE: Firebase (restricted in Nigeria)
# FIREBASE_PROJECT_ID=...
# FIREBASE_PRIVATE_KEY=...
# FIREBASE_CLIENT_EMAIL=...

# Ads - Unity Ads (Nigeria ✓)
UNITY_GAME_ID_IOS=6060849
UNITY_GAME_ID_ANDROID=6060848
UNITY_PLACEMENT_ID=rewardedVideo
UNITY_ENABLED=true

# Security (Generate strong key)
SECRET_KEY=your-random-secret-key-min-32-chars-long

# CORS (Update with your actual frontend URL)
CORS_ORIGINS=["https://your-app.onrender.com", "http://localhost:3000"]
